{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "OpenScreen",
	"version": "1.2.0",
	"identifier": "com.siddharthvaddem.openscreen",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "npm run build-vite",
		"beforeDevCommand": "npm run dev"
	},
	"app": {
		"macOSPrivateApi": true,
		"trayIcon": {
			"iconPath": "icons/icon.png",
			"iconAsTemplate": true
		},
		"security": {
			"csp": null
		},
		"windows": []
	},
	"plugins": {
		"fs": {
			"all": true,
			"scope": ["$APPDATA/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$RESOURCE/**"]
		},
		"dialog": {
			"all": true
		},
		"opener": {}
	},
	"bundle": {
		"active": true,
		"targets": ["dmg", "nsis", "appimage"],
		"resources": ["../public/wallpapers", "../public/wasm"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"windows": {
			"nsis": {
				"installMode": "both",
				"languages": ["SimpChinese", "English", "Spanish"]
			}
		},
		"macOS": {
			"minimumSystemVersion": "10.13"
		}
	}
}
